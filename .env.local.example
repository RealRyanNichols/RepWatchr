# RepWatchr local environment example
# Copy to .env.local for local development. Never commit real secrets.

# Site URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Supabase public/browser auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_SUPABASE_AUTH=true
NEXT_PUBLIC_ENABLE_SUPABASE_REPORTS=true
# Legacy Texas-only contribution table flag. Active source intake uses /api/source-submissions.
NEXT_PUBLIC_TEXAS_ELECTION_DB_SUBMISSIONS=false
# Configure the matching secret in Supabase Auth CAPTCHA settings before enabling.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Supabase server/admin operations
SUPABASE_SERVICE_ROLE_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
ANALYTICS_HASH_SECRET=

# Cron and integration health
CRON_SECRET=
INTEGRATION_HEALTH_SECRET=

# Stripe profile subscription flow
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_WEBHOOK_SECRET=
IDENTITY_VERIFICATION_ENABLED=false
STRIPE_PROFILE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PROFILE_PRICE_ID=

# RepWatchr service checkout
# Service prices are controlled server-side in src/lib/repwatchr-payment-products.ts.
# No NEXT_PUBLIC Stripe payment links are used for service checkout.

# Faretta / Gideon AI bridge
FARETTA_CHAT_URL=
NEXT_PUBLIC_FARETTA_CHAT_URL=
FARETTA_CHAT_BEARER=
FARETTA_INTERACTIONS_TABLE=faretta_interactions
FARETTA_INTAKE_SECRET=
GIDEON_CHAT_URL=
NEXT_PUBLIC_GIDEON_CHAT_URL=
GIDEON_CHAT_BEARER=

# Member/report hashing
MEMBER_SESSION_SECRET=
REPORT_INTAKE_HASH_SECRET=
IDENTITY_HMAC_SECRET=
TURNSTILE_SECRET_KEY=

# Social posting setup
SOCIAL_AUTH_SETUP_SECRET=
SOCIAL_AUTOPOST_ENABLED=false
SOCIAL_AUTOPOST_EDITORIAL_APPROVED=false
SOCIAL_AUTOPOST_MAX_AGE_HOURS=36
SOCIAL_AUTOPOST_SOURCE_LIMIT=8

# Facebook page posting
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_VERSION=v24.0

# X OAuth and posting
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=
X_USER_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_POST_ENDPOINT=https://api.x.com/2/tweets
X_AUTOPOST_ENABLED=false
X_API_BEARER_TOKEN=
X_BEARER_TOKEN=
X_API_KEY=

# LeadRep Orchestrator (server-side only; never use NEXT_PUBLIC_)
XAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
LEADREP_BUS_URL=https://rgxboswrinsuakxqstyc.supabase.co
LEADREP_BUS_SERVICE_KEY=
LEADREP_GROK_MODE=dry_run
LEADREP_APPROVAL_MODE=manual
LEADREP_API_SECRET=
GROK_MAX_DAILY_COST_USD=10
LEADREP_GITHUB_REPOSITORY=RealRyanNichols/RepWatchr
LEADREP_VERCEL_PROJECT=realryannichols/repwatchr
