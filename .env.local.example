# Supabase Configuration
# Get these from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase-backed public flows default ON when URL/key are configured.
# Set any of these to false only as an emergency kill switch.
NEXT_PUBLIC_ENABLE_SUPABASE_AUTH=true
NEXT_PUBLIC_ENABLE_SUPABASE_REPORTS=true
NEXT_PUBLIC_TEXAS_ELECTION_DB_SUBMISSIONS=true

# Public site URL for Stripe redirects
NEXT_PUBLIC_SITE_URL=https://www.repwatchr.com

# Hourly source-linked social autoposting.
# Keep SOCIAL_AUTOPOST_EDITORIAL_APPROVED=false until credentials, source policy,
# duplicate protection, and message format have been reviewed in production.
CRON_SECRET=replace-with-random-secret
SOCIAL_AUTOPOST_ENABLED=false
SOCIAL_AUTOPOST_EDITORIAL_APPROVED=false
SOCIAL_AUTOPOST_MAX_AGE_HOURS=72
SOCIAL_AUTOPOST_SOURCE_LIMIT=24
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_VERSION=v24.0
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REFRESH_TOKEN=
X_USER_ACCESS_TOKEN=

# GideonAI chat bridge
# Server-side proxy target for the GideonAI Supabase Edge Function.
# Example: https://<project-ref>.functions.supabase.co/gideon-chat
GIDEON_CHAT_URL=
# Optional bearer token if the Gideon Edge Function requires one.
GIDEON_CHAT_BEARER=
# Optional public URL only if you intentionally want browser-side widgets to call Gideon directly.
NEXT_PUBLIC_GIDEON_CHAT_URL=

# Stripe profile membership subscriptions
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PROFILE_PRICE_ID=price_your_profile_membership_price
# Optional fallback if you need to expose the selected price ID in client copy later
NEXT_PUBLIC_STRIPE_PROFILE_PRICE_ID=price_your_profile_membership_price

# Google Analytics (optional)
# Get from https://analytics.google.com/ - create a GA4 property
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
